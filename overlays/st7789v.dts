/dts-v1/;
/plugin/;

/ {
	compatible = "bananapi,bpi-m4zero", "allwinner,sun50i-h616";

	fragment@0 {
		target = <&spi1>;
		__overlay__ {
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";

			st7789v@0 {
				compatible = "sitronix,st7789v";
				reg = <0>;
				spi-max-frequency = <64000000>;
				buswidth = <8>;
				dc-gpios = <&pio 8 16 0>;
				reset-gpios = <&pio 2 2 1>;
				rotate = <0>;
				bgr;
				width = <240>;
				height = <280>;
				fps = <30>;
				status = "okay";
			};
		};
	};
};
